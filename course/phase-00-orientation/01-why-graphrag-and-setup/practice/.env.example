# 이 파일을 .env 로 복사해서 값을 채운다: cp .env.example .env
# .env 는 절대 커밋하지 않는다.

# --- 상용 API 키 ---
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# --- Neo4j 접속 정보 (docker-compose.yml 과 일치시킬 것) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

# --- 비용 대안 분기 (선택) ---
# 임베딩을 로컬 bge-m3 로 바꾸려면 1 로 설정한다. 기본은 VoyageAI.
USE_LOCAL_EMBEDDING=0
