# 08-lightrag-neo4j-ops — 환경 변수 예시
#
# 이 파일을 .env 로 복사해 값을 채운다.  cp .env.example .env
# .env 는 절대 커밋하지 않는다(.gitignore). 키는 os.environ/.env 에서만 읽는다.
#
# 07 의 BASIC / OLLAMA 두 프로파일을 그대로 잇고, Neo4j 블록과 동시성 블록을 더했다.
#   (A) 본 과정 기본 = Claude + VoyageAI  (아래 'BASIC' 블록 사용, 'OLLAMA' 블록 주석)
#   (B) 비용 0 대안  = Ollama + bge-m3     (아래 'OLLAMA' 블록 주석 해제, 'BASIC' 블록 주석)

# ===== 공통 (API 서버 / WebUI) ===========================================
HOST=0.0.0.0
PORT=9621
WORKERS=2
SUMMARY_LANGUAGE=Korean         # 엔티티·관계 요약을 한국어로
WORKING_DIR=./rag_storage       # KV/Vector/DocStatus 는 여기 남는다(그래프만 Neo4j 로 감)

# ===== 그래프 스토리지 = Neo4j (08 의 핵심) ==============================
# graph_storage 만 Neo4j 로 바꾼다 → KG(엔티티·관계)만 Neo4j 로 가고
# KV/Vector/DocStatus 는 여전히 WORKING_DIR(파일)에 남는다.
# 백엔드는 문서 추가 전에 정해야 한다(중간 전환 불가 — 새 DB/working_dir 로 재인덱싱 필요).
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me   # docker-compose.yml 의 NEO4J_AUTH 와 같은 값으로
NEO4J_DATABASE=neo4j              # community edition 은 이 값이 필수(누락 시 연결 실패)

# ===== 동시성 (레이트리밋 + Neo4j 동시 쓰기 부하 고려해 낮게 시작) ========
MAX_ASYNC_LLM=8                 # 동시 LLM 호출 상한
MAX_PARALLEL_INSERT=3           # 동시 인덱싱 문서 수
EMBEDDING_FUNC_MAX_ASYNC=16     # 임베딩 동시성
EMBEDDING_BATCH_NUM=32          # 임베딩 배치 크기

# ===== 캐시 (재인덱싱·반복 질의 비용 절감) ================================
# 둘 다 기본 True. 끄려면 false 로. 캐시는 KV 스토리지에 저장된다.
ENABLE_LLM_CACHE=true                 # 질의 LLM 캐시(같은 질문 반복 시 즉답)
ENABLE_LLM_CACHE_FOR_EXTRACT=true     # 추출 단계 캐시(같은 청크 재추출 비용 절감)

# ===== (A) BASIC — Claude + VoyageAI =====================================
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

LLM_BINDING=anthropic
LLM_MODEL=claude-3-5-haiku-latest
LLM_BINDING_API_KEY=${ANTHROPIC_API_KEY}

EMBEDDING_BINDING=voyageai
EMBEDDING_MODEL=voyage-3.5
EMBEDDING_DIM=1024              # voyage-3.5 기본 차원
EMBEDDING_BINDING_API_KEY=${VOYAGE_API_KEY}

RERANK_BINDING=null

# ===== (B) OLLAMA — 비용 0 대안 (bge-m3) =================================
# 위 BASIC 블록을 주석 처리하고 아래를 주석 해제한다.
# 사전 준비: Ollama 데몬 실행 + `ollama pull qwen2.5` + `ollama pull bge-m3`
#
# BACKEND=ollama               # index_neo4j.py 의 build_backend 분기 키
# LLM_BINDING=ollama
# LLM_MODEL=qwen2.5
# LLM_BINDING_HOST=http://localhost:11434
#
# EMBEDDING_BINDING=ollama
# EMBEDDING_MODEL=bge-m3
# EMBEDDING_DIM=1024           # bge-m3 차원
# EMBEDDING_BINDING_HOST=http://localhost:11434
#
# RERANK_BINDING=null
